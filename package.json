{
  "name": "lawnpal",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,mobile \"npm:dev:api\" \"npm:dev:mobile\"",
    "dev:mobile": "npm --workspace @lawnpal/mobile run dev",
    "dev:api": "npm --workspace @lawnpal/api run dev",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "9.1.2",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
